generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                 String            @id @default(cuid())
  name               String?
  email              String            @unique
  emailVerified      DateTime?         @map("email_verified")
  image              String?
  credits            Int               @default(0)
  subscription_tier  String?
  stripe_customer_id String?
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  password           String?
  ab_tests           ab_tests[]
  accounts           Account[]
  render_jobs        RenderJob[]
  scheduled_posts    scheduled_posts[]
  series             series[]
  sessions           Session[]
  videos             Video[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Video {
  id           String      @id @default(cuid())
  title        String
  description  String?
  script       String?
  status       String      @default("draft")
  style        String?
  voice_type   String?
  music_track  String?
  thumbnailUrl String?     @map("thumbnail_url")
  video_url    String?
  duration     Int?
  creditsUsed  Int         @default(0) @map("credits_used")
  userId       String      @map("user_id")
  series_id    String?
  scheduled_at DateTime?
  published_at DateTime?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  renderJobs   RenderJob[]
  series       series?     @relation(fields: [series_id], references: [id])
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("videos")
}

model RenderJob {
  id          String       @id @default(cuid())
  status      RenderStatus @default(PENDING)
  progress    Int          @default(0)
  output_url  String?
  error       String?
  job_data    Json?
  worker_id   String?
  attempts    Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  startedAt   DateTime?    @map("started_at")
  completedAt DateTime?    @map("completed_at")
  videoId     String       @map("video_id")
  user_id     String
  users       User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video       Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
  @@index([user_id])
  @@index([videoId])
  @@map("render_jobs")
}

model ab_test_variations {
  id                 String   @id
  name               String
  thumbnail_url      String
  title              String?
  description        String?
  traffic_allocation Int      @default(50)
  impressions        Int      @default(0)
  clicks             Int      @default(0)
  views              Int      @default(0)
  engagement         Float    @default(0)
  ctr                Float    @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime
  ab_test_id         String
  ab_tests           ab_tests @relation(fields: [ab_test_id], references: [id], onDelete: Cascade)

  @@index([ab_test_id])
}

model ab_tests {
  id                 String               @id
  name               String
  description        String?
  status             ABTestStatus         @default(DRAFT)
  hypothesis         String?
  video_id           String
  start_date         DateTime?
  end_date           DateTime?
  target_metric      String               @default("CTR")
  winner_id          String?
  confidence         Float?
  created_at         DateTime             @default(now())
  updated_at         DateTime
  user_id            String
  ab_test_variations ab_test_variations[]
  users              User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([user_id])
  @@index([video_id])
}

model credit_transactions {
  id          String   @id
  user_id     String
  amount      Int
  type        String
  description String?
  created_at  DateTime @default(now())
}

model niches {
  id          String   @id
  name        String   @unique
  description String?
  trend_score Float    @default(0)
  competition Float    @default(0)
  volume      Int      @default(0)
  growth      Float    @default(0)
  category    String
  tags        String[]
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime

  @@index([category])
  @@index([competition])
  @@index([is_active])
  @@index([trend_score])
}

model scheduled_posts {
  id             String         @id
  title          String
  description    String?
  scheduled_at   DateTime
  timezone       String         @default("UTC")
  status         ScheduleStatus @default(SCHEDULED)
  platforms      Platform[]
  platform_ids   Json?
  video_url      String
  thumbnail_url  String?
  auto_publish   Boolean        @default(true)
  notify_on_post Boolean        @default(true)
  posted_at      DateTime?
  post_urls      Json?
  error          String?
  created_at     DateTime       @default(now())
  updated_at     DateTime
  user_id        String
  users          User           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([scheduled_at])
  @@index([status])
  @@index([user_id])
}

model series {
  id              String   @id
  name            String
  description     String?
  niche           String?
  user_id         String
  is_auto_publish Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime
  users           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  videos          Video[]
}

enum ABTestStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum Platform {
  TIKTOK
  YOUTUBE_SHORTS
  INSTAGRAM_REELS
}

enum RenderStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ScheduleStatus {
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum SubtitlePosition {
  TOP
  CENTER
  BOTTOM

  @@map("subtitle_position")
}

model SubtitleStyle {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  presetType        String   @map("preset_type")

  // Typography
  fontFamily        String   @map("font_family")
  fontSize          Int      @map("font_size")
  fontWeight        String   @map("font_weight")
  fontStyle         String?  @map("font_style")
  textTransform     String?  @map("text_transform")
  letterSpacing     String?  @map("letter_spacing")

  // Colors
  textColor         String   @map("text_color")
  backgroundColor   String?  @map("background_color")
  backgroundOpacity Float?   @map("background_opacity")
  outlineColor      String?  @map("outline_color")
  outlineWidth      Int?     @map("outline_width")
  highlightColor    String?  @map("highlight_color")

  // Layout
  position          SubtitlePosition @default(BOTTOM) @map("position")
  padding           String?  @map("padding")
  borderRadius      String?  @map("border_radius")

  // Animation
  animationEnabled  Boolean  @default(false) @map("animation_enabled")
  animationType     String?  @map("animation_type")

  // Features
  karaokeStyle      Boolean  @default(false) @map("karaoke_style")
  shadowEnabled     Boolean  @default(true) @map("shadow_enabled")
  emojiEnabled      Boolean  @default(false) @map("emoji_enabled")

  // Meta
  isPreset          Boolean  @default(true) @map("is_preset")
  isCustom          Boolean  @default(false) @map("is_custom")
  previewText       String?  @map("preview_text")
  previewGradient   String?  @map("preview_gradient")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdBy         String?  @map("created_by")

  @@map("subtitle_styles")
}

model MusicTrack {
  id          String   @id @default(cuid())
  title       String
  artist      String
  category    String
  duration    Int      // in seconds
  url         String
  coverArt    String?  @map("cover_art")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("music_tracks")
}
