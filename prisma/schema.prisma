generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Style {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  previewGradient String @map("preview_gradient")
  primaryColor    String @map("primary_color")
  secondaryColor  String @map("secondary_color")
  accentColor     String @map("accent_color")
  fontPair        String @map("font_pair")
  isCustom        Boolean  @default(false) @map("is_custom")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdBy       String?  @map("created_by")

  @@map("styles")
}

model CustomStyle {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  primaryColor    String @map("primary_color")
  secondaryColor  String @map("secondary_color")
  accentColor     String @map("accent_color")
  backgroundColor String @map("background_color")
  textColor       String @map("text_color")
  fontHeading     String @map("font_heading")
  fontBody        String @map("font_body")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("custom_styles")
}

enum VoiceCategory {
  MALE
  FEMALE
  NEUTRAL

  @@map("voice_category")
}

enum VoiceProvider {
  ELEVENLABS
  EDGE_TTS
  CUSTOM

  @@map("voice_provider")
}

model Voice {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    VoiceCategory
  provider    VoiceProvider @default(ELEVENLABS)
  accent      String?
  language    String   @default("tr")
  previewUrl  String?  @map("preview_url")
  avatarUrl   String?  @map("avatar_url")
  isActive    Boolean  @default(true) @map("is_active")
  isPremium   Boolean  @default(false) @map("is_premium")
  metadata    Json?    // For additional voice settings like pitch range, speed range
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("voices")
}

model CustomVoice {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  sampleUrl   String   @map("sample_url")
  voiceId     String?  @map("voice_id") // External voice ID from provider
  provider    VoiceProvider @default(CUSTOM)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("custom_voices")
}
